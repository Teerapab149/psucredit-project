generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  studentId        String?         @unique
  name             String?
  passwordHash     String
  role             Role            @default(STUDENT)
  curriculumYear   CurriculumYear? @relation(fields: [curriculumYearId], references: [id])
  curriculumYearId String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  userSubjects     UserSubject[]
  studyPlans       StudyPlan[] // เพิ่ม: รองรับฟีเจอร์ Saved Plan
}

enum Role {
  STUDENT
  ADMIN
}

model CurriculumYear {
  id         String  @id @default(cuid())
  startYear  Int?
  endYear    Int?
  name       String
  faculty    String?
  department String?
  major      String?
  track      String?
  isActive   Boolean @default(true)
  isTemplate Boolean @default(false)

  baseTemplateId   String?
  baseTemplate     CurriculumYear?  @relation("TemplateRelation", fields: [baseTemplateId], references: [id])
  derivedTemplates CurriculumYear[] @relation("TemplateRelation")

  categories CurriculumCategory[]
  users      User[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
}

model CurriculumCategory {
  id                      String               @id @default(cuid())
  name                    String
  requiredCredits         Int
  minCredits              Int?
  maxCredits              Int?
  isElective              Boolean              @default(false)
  sortOrder               Int                  @default(0)
  parentId                String?
  parent                  CurriculumCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children                CurriculumCategory[] @relation("CategoryHierarchy")
  inheritedFromCategoryId String?
  spilloverType           SpilloverType?
  curriculumYear          CurriculumYear       @relation(fields: [curriculumYearId], references: [id], onDelete: Cascade)
  curriculumYearId        String
  subjects                Subject[]
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
}

model Subject {
  id              String              @id @default(cuid())
  code            String
  name            String
  credits         Int
  categoryId      String?
  category        CurriculumCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subjectGroup    String?             // e.g., 'GE1', 'Core'
  // Link back to the Global Subject Bank entry this row was cloned from.
  // SetNull: removing a MasterSubject orphans curriculum copies — it does NOT delete them.
  masterSubjectId String?
  masterSubject   MasterSubject?      @relation(fields: [masterSubjectId], references: [id], onDelete: SetNull)
  userSubjects    UserSubject[]
  planSubjects    PlanSubject[]       // เพิ่ม: ความสัมพันธ์กับวิชาจำลอง
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([code, categoryId])
}

// ประวัติการเรียนจริง (ดึงจากไฟล์ PDF)
model UserSubject {
  id        String        @id @default(cuid())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  subject   Subject?      @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  subjectId String?
  code      String
  name      String
  credits   Int
  grade     String?
  status    SubjectStatus @default(PASSED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, code])
}

// --- ส่วนที่เพิ่มใหม่สำหรับการจำลองผลการเรียน ---

model StudyPlan {
  id           String        @id @default(cuid())
  name         String        @default("แผนการเรียนจำลอง")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  planSubjects PlanSubject[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model PlanSubject {
  id            String    @id @default(cuid())
  plan          StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  planId        String
  subject       Subject?  @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  subjectId     String?
  code          String
  name          String
  credits       Int
  expectedGrade String? // เก็บเกรดสมมติ
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([planId, code]) // ป้องกันการลงวิชาซ้ำในแผนเดียวกัน
}

enum SubjectStatus {
  PASSED
  IN_PROGRESS
  FAILED
  WITHDRAWN
}

enum SpilloverType {
  MINOR
  FREE_ELECTIVE
}

model SubjectEquivalency {
  id        String   @id @default(cuid())
  newCode   String   @unique // e.g., "315-202G2B"
  baseCode  String   // e.g., "315-202"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Global Subject Bank — master catalog independent of any curriculum
model MasterSubject {
  id           String    @id @default(cuid())
  code         String    @unique
  name         String
  credits      Int
  subjectGroup String?   // e.g., 'GE1', 'Core', 'Free Elective'
  tags         String[]  // e.g., ['math', 'required']
  // All curriculum Subject rows that were cloned from this master entry
  subjects     Subject[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
